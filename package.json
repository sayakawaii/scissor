{
  "name": "scissor",
  "version": "0.2.0",
  "private": true,
  "description": "A personal Cursor-like terminal AI coding agent",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "node --import tsx packages/cli/src/index.ts",
    "scissor": "node --import tsx packages/cli/src/index.ts",
    "typecheck": "tsc --noEmit -p packages/core && tsc --noEmit -p packages/cli",
    "test": "node --import tsx scripts/test-session.mts && node --import tsx scripts/test-selfupdate.mts && node --import tsx scripts/test-retrieve.mts && node --import tsx scripts/test-verify-loop.mts",
    "smoke": "node --import tsx scripts/smoke.mts",
    "smoke:plan": "node --import tsx scripts/smoke-plan.mts",
    "smoke:restart": "node --import tsx scripts/smoke-restart.mts",
    "smoke:verify": "node --import tsx scripts/smoke-verify.mts",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
